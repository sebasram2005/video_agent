# Environment — never commit API keys
.env
.env.local

# Generated output — videos and landings (large files, not tracked)
output/mvp_*/
output/curated/latest.json
temp/

# Curated story JSONs ARE tracked (GitHub Actions needs them)
!output/curated/
!output/curated/*.json

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Large binary assets — add your own gameplay/music locally
assets/gameplay/
assets/music/

# OS
.DS_Store
Thumbs.db
